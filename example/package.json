{
  "name": "adadapted-react-native-sdk-example",
  "description": "Example app for adadapted-react-native-sdk",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-native start --reset-cache",
    "run-android": "JAVA_HOME=$(/usr/libexec/java_home -v 21) ANDROID_HOME=$HOME/Library/Android/sdk npx react-native run-android",
    "log-android": "JAVA_HOME=$(/usr/libexec/java_home -v 21) ANDROID_HOME=$HOME/Library/Android/sdk npx react-native log-android",
    "ios-sim-boot": "sh scripts/ios-sim-boot.sh",
    "ios-sim-launch": "sh scripts/ios-sim-launch.sh",
    "ios-sim-build": "sh scripts/ios-sim-build.sh",
    "ios-sim-log": "sh scripts/ios-sim-log.sh"
  },
  "dependencies": {
    "@react-native/gradle-plugin": "0.86.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "axios": "^1.7.9",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-base64": "^0.2.2",
    "react-native-intersection-observer": "^0.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-webview": "^13.16.1",
    "react-router-native": "^6.30.3"
  },
  "devDependencies": {
    "@react-native-community/cli": "20.2.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "react-test-renderer": "19.2.7"
  }
}
